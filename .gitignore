# Compiled binaries
/bin/

# Local environment overrides
.env

# Per-environment secret overlays (never commit)
deploy/*/secrets.yaml

# Helm subchart artifacts (fetched via `helm dependency build`; Chart.lock is committed)
deploy/charts/baseline/charts/
deploy/charts/baseline/*.tgz

# Personal Claude Code settings (cluster URL, principal)
.claude/settings.local.json

# Local MCP configs (use the plugin instead; these leak local paths)
.mcp.json
.mcp.*.json
